// ── IZIPAY PAYMENT (Form POST redirect) ──
const SHOP_ID   = '61366189';
const SHOP_KEY  = 'taGWGNQ4TyZhh4rx'; // production key

function padLeft(str, length, char) {
  str = String(str);
  while (str.length < length) str = char + str;
  return str;
}

function getTransDate() {
  const now = new Date();
  return now.getUTCFullYear()
    + padLeft(now.getUTCMonth()+1, 2, '0')
    + padLeft(now.getUTCDate(), 2, '0')
    + padLeft(now.getUTCHours(), 2, '0')
    + padLeft(now.getUTCMinutes(), 2, '0')
    + padLeft(now.getUTCSeconds(), 2, '0');
}

function getTransId() {
  // 6-char alphanumeric unique ID based on time
  return padLeft(Math.floor(Date.now() / 1000) % 900000 + 100000, 6, '0');
}

async function computeHmacSha256(message, key) {
  const encoder = new TextEncoder();
  const keyData = encoder.encode(key);
  const msgData = encoder.encode(message);
  const cryptoKey = await crypto.subtle.importKey('raw', keyData, {name:'HMAC', hash:'SHA-256'}, false, ['sign']);
  const signature = await crypto.subtle.sign('HMAC', cryptoKey, msgData);
  return Array.from(new Uint8Array(signature)).map(b => b.toString(16).padStart(2,'0')).join('');
}

async function submitToIzipay() {
  const btn = document.getElementById('payNowBtn');
  btn.disabled = true;
  document.getElementById('processingOverlay').classList.add('show');

  const returnUrl = window.location.origin + window.location.pathname + '?plan=' + (urlParams.get('plan') || 'edify-monthly') + '&status=paid';
  const cancelUrl = window.location.href;

  const fields = {
    vads_action_mode:     'INTERACTIVE',
    vads_amount:          String(plan.price * 100),
    vads_ctx_mode:        'PRODUCTION',
    vads_currency:        '840', // USD
    vads_page_action:     'PAYMENT',
    vads_payment_config:  'SINGLE',
    vads_site_id:         SHOP_ID,
    vads_trans_date:      getTransDate(),
    vads_trans_id:        getTransId(),
    vads_version:         'V2',
    vads_url_return:      returnUrl,
    vads_url_cancel:      cancelUrl,
    vads_url_success:     returnUrl,
    vads_order_id:        'BLINK-' + Date.now(),
    vads_cust_email:      document.getElementById('f-email').value.trim(),
    vads_cust_first_name: document.getElementById('f-name').value.trim().split(' ')[0],
    vads_cust_last_name:  document.getElementById('f-name').value.trim().split(' ').slice(1).join(' ') || '-',
    vads_cust_phone:      document.getElementById('f-country').value + document.getElementById('f-phone').value.trim()
  };

  // Build signature string: sort vads_ fields alphabetically, join values with +, append key
  const sortedKeys = Object.keys(fields).filter(k => k.startsWith('vads_')).sort();
  const signatureContent = sortedKeys.map(k => fields[k]).join('+') + '+' + SHOP_KEY;
  const signature = await computeHmacSha256(signatureContent, SHOP_KEY);

  // Build and submit hidden form
  const form = document.getElementById('izipayHiddenForm');
  form.innerHTML = '';
  [...sortedKeys, ...Object.keys(fields).filter(k => !k.startsWith('vads_'))].forEach(k => {
    if (fields[k] !== undefined) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = k;
      input.value = fields[k];
      form.appendChild(input);
    }
  });
  const sigInput = document.createElement('input');
  sigInput.type = 'hidden';
  sigInput.name = 'signature';
  sigInput.value = signature;
  form.appendChild(sigInput);

  form.submit();
}

