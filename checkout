let currentStep = 1;

function updateProgress(step) {
  [1,2,3].forEach(i => {
    const si = document.getElementById('si-' + i);
    const sc = document.getElementById('sc-' + i);
    si.classList.remove('active','completed');
    if (i < step) { si.classList.add('completed'); sc.textContent = '✓'; }
    else { sc.textContent = i; if (i === step) si.classList.add('active'); }
  });
}

function goTo(step, back) {
  document.getElementById('step-' + currentStep).classList.remove('active');
  const next = document.getElementById('step-' + step);
  next.classList.remove('back');
  if (back) next.classList.add('back');
  next.classList.add('active');
  currentStep = step;
  updateProgress(step);
  window.scrollTo({top:0,behavior:'smooth'});
}

